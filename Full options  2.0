local function RefreshPlayers()
    local p_list = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer then table.insert(p_list, p.Name) end
    end
    PlayerDropdown:Refresh(p_list)
end

PlayerTab:CreateButton({Name = "🔄 อัปเดตรายชื่อผู้เล่น", Callback = function() RefreshPlayers() end})

