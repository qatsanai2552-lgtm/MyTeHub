local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "💎 TeHub | Premium 💎",
   LoadingTitle = "By เต้ อัสนัย",
   LoadingSubtitle = "Premium Script By Te Assanai",
   ConfigurationPath = "TeHubConfig"
})

local _G = {
    Enabled = false,
    Hitbox = false,
    ESP_Enabled = false,
    ESP_Mode = "All Players",
    ShowTracers = false,
    FOV = 120,
    HitboxSize = 12,
    Smoothness = 0.05,
    TargetPart = "Head",
    SelectedPlayer = "",
    SpeedValue = 16
}

local fovCircle = Drawing.new("Circle")
fovCircle.Thickness = 1
fovCircle.Transparency = 0.5
fovCircle.Color = Color3.fromRGB(255, 255, 255)
fovCircle.Visible = false
fovCircle.Filled = false
fovCircle.NumSides = 64

local MainTab = Window:CreateTab("Combat", 4483362458)
local ESPTab = Window:CreateTab("ESP", 4483362458)
local PlayerTab = Window:CreateTab("Players", 4483362458)
local SettingTab = Window:CreateTab("Settings", 4483362458)

MainTab:CreateSection("Aimbot Settings")
MainTab:CreateToggle({
   Name = "เปิดระบบ Aimbot (Auto Smart Lock)",
   CurrentValue = false,
   Callback = function(Value)
      _G.Enabled = Value
      fovCircle.Visible = Value
   end,
})

MainTab:CreateSlider({
   Name = "ระยะ FOV",
   Range = {50, 500},
   Increment = 10,
   CurrentValue = 120,
   Callback = function(Value) _G.FOV = Value end,
})

MainTab:CreateSlider({
   Name = "ความหน่วงการล็อก (Smoothness)",
   Range = {0.01, 1},
   Increment = 0.01,
   CurrentValue = 0.05,
   Callback = function(Value) _G.Smoothness = Value end,
})

MainTab:CreateSection("Hitbox Settings")
MainTab:CreateToggle({
   Name = "เปิดระบบ Big Hitbox (เฉพาะศัตรู)",
   CurrentValue = false,
   Callback = function(Value) _G.Hitbox = Value end,
})

MainTab:CreateSlider({
   Name = "ขนาด Hitbox",
   Range = {2, 50},
   Increment = 1,
   CurrentValue = 12,
   Callback = function(Value) _G.HitboxSize = Value end,
})

ESPTab:CreateSection("ESP Control")
ESPTab:CreateToggle({
   Name = "เปิดระบบมองผู้เล่น (ESP)",
   CurrentValue = false,
   Callback = function(Value) _G.ESP_Enabled = Value end,
})

ESPTab:CreateToggle({
   Name = "เปิดเส้นลาก (Tracers)",
   CurrentValue = false,
   Callback = function(Value) _G.ShowTracers = Value end,
})

ESPTab:CreateDropdown({
   Name = "โหมดการมอง",
   Options = {"All Players", "Selected Only"},
   CurrentOption = "All Players",
   Callback = function(Option) _G.ESP_Mode = Option end,
})

PlayerTab:CreateSection("Character Speed")
PlayerTab:CreateSlider({
   Name = "ความเร็วการเดิน (Speed)",
   Range = {16, 250},
   Increment = 1,
   Suffix = "Speed",
   CurrentValue = 16,
   Callback = function(Value) _G.SpeedValue = Value end,
})

PlayerTab:CreateSection("Player Interaction")
local PlayerDropdown = PlayerTab:CreateDropdown({
   Name = "เลือกผู้เล่น",
   Options = {},
   CurrentOption = "",
   Callback = function(Option)
      if type(Option) == "table" then _G.SelectedPlayer = Option[1] else _G.SelectedPlayer = Option end
   end,
})

local function RefreshPlayers()
    local p_list = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer then table.insert(p_list, p.Name) end
    end
    PlayerDropdown:Refresh(p_list)
end

PlayerTab:CreateButton({Name = "🔄 รีเซ็ตรายชื่อคนในแมพ", Callback = function() RefreshPlayers() end})

PlayerTab:CreateButton({
   Name = "🚀 วาร์ปไปหา (Teleport)",
   Callback = function()
       local target = game.Players:FindFirstChild(_G.SelectedPlayer)
       if target and target.Character then
           game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
       end
   end,
})

PlayerTab:CreateButton({
   Name = "👁️ ดูคนนี้ (Spectate)",
   Callback = function()
       local target = game.Players:FindFirstChild(_G.SelectedPlayer)
       if target and target.Character then workspace.CurrentCamera.CameraSubject = target.Character.Humanoid end
   end,
})

PlayerTab:CreateButton({
   Name = "🔙 กลับมาดูตัวเอง",
   Callback = function()
       workspace.CurrentCamera.CameraSubject = game.Players.LocalPlayer.Character.Humanoid
   end,
})

SettingTab:CreateSection("Optimization")
SettingTab:CreateButton({
   Name = "🚀 FPS Boost (ลดแลค)",
   Callback = function()
       for _, v in pairs(game:GetDescendants()) do
           if v:IsA("Part") or v:IsA("MeshPart") then v.Material = "SmoothPlastic" v.Reflectance = 0
           elseif v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end
       end
   end,
})

SettingTab:CreateSection("Credits")
local creditLabel = SettingTab:CreateParagraph({Title = "Script Developed By:", Content = "By เต้ อัสนัย"})

local function CreateESP(plr)
    local Box = Drawing.new("Square")
    Box.Visible = false
    Box.Color = Color3.fromRGB(0, 255, 0)
    Box.Thickness = 1
    Box.Filled = false

    local Name = Drawing.new("Text")
    Name.Visible = false
    Name.Center = true
    Name.Outline = true
    Name.Size = 13
    Name.Color = Color3.fromRGB(255, 255, 255)

    local Tracer = Drawing.new("Line")
    Tracer.Visible = false
    Tracer.Color = Color3.fromRGB(255, 255, 255)
    Tracer.Thickness = 1

    game:GetService("RunService").RenderStepped:Connect(function()
        local shouldShow = false
        if _G.ESP_Enabled and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") then
            if plr.Character.Humanoid.Health > 0 then
                if _G.ESP_Mode == "All Players" then shouldShow = true
                elseif _G.ESP_Mode == "Selected Only" and plr.Name == _G.SelectedPlayer then shouldShow = true end
            end
        end

        if shouldShow then
            local r_pos, vis = workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
            if vis then
                local size = (workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position - Vector3.new(0, 3, 0)).Y - workspace.CurrentCamera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position + Vector3.new(0, 2.6, 0)).Y)
                local width = size / 1.5
                
                Box.Size = Vector2.new(width, size)
                Box.Position = Vector2.new(r_pos.X - width / 2, r_pos.Y - size / 2)
                Box.Color = (plr.Team ~= game.Players.LocalPlayer.Team) and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
                Box.Visible = true

                Name.Position = Vector2.new(r_pos.X, r_pos.Y + (size / 2) + 2)
                Name.Text = plr.Name
                Name.Visible = true

                if _G.ShowTracers then
                    Tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)
                    Tracer.To = Vector2.new(r_pos.X, r_pos.Y + (size / 2))
                    Tracer.Visible = true
                else Tracer.Visible = false end
            else Box.Visible = false Name.Visible = false Tracer.Visible = false end
        else Box.Visible = false Name.Visible = false Tracer.Visible = false end
    end)
end

for _, v in pairs(game.Players:GetPlayers()) do if v ~= game.Players.LocalPlayer then CreateESP(v) end end
game.Players.PlayerAdded:Connect(function(v) CreateESP(v) end)

game:GetService("RunService").RenderStepped:Connect(function()
    local lp = game.Players.LocalPlayer
    local camera = workspace.CurrentCamera
    
    if fovCircle.Visible then
        fovCircle.Radius = _G.FOV
        fovCircle.Position = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
    end
    
    if _G.Enabled then
        local target = nil
        local shortestDist = _G.FOV
        
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild(_G.TargetPart) and v.Character:FindFirstChild("Humanoid") then
                -- เช็คเลือดและเช็คทีม (ไม่ล็อกเพื่อน)
                if v.Character.Humanoid.Health > 0 and (v.Team ~= lp.Team or v.Team == nil) then
                    local pos, vis = camera:WorldToViewportPoint(v.Character[_G.TargetPart].Position)
                    if vis then
                        local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)).Magnitude
                        if mag < shortestDist then
                            shortestDist = mag
                            target = v.Character[_G.TargetPart]
                        end
                    end
                end
            end
        end

        if target then
            -- ระบบคํานวณความแรงอัตโนมัติ (ยิ่งใกล้ ยิ่งดูดเป้าแรง)
            local worldDist = (lp.Character.HumanoidRootPart.Position - target.Position).Magnitude
            local dynamicSmooth = _G.Smoothness
            
            if worldDist < 60 then dynamicSmooth = _G.Smoothness * 1.5 end
            if worldDist < 30 then dynamicSmooth = _G.Smoothness * 2.5 end
            if worldDist < 10 then dynamicSmooth = 0.8 end -- ระยะประชิดล็อกติดหนึบ
            
            camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, target.Position), math.clamp(dynamicSmooth, 0, 1))
        end
    end

    if lp.Character and lp.Character:FindFirstChild("Humanoid") then
        lp.Character.Humanoid.WalkSpeed = _G.SpeedValue
        if _G.Hitbox then
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    -- ขยาย Hitbox เฉพาะศัตรู
                    if (p.Team ~= lp.Team or p.Team == nil) then
                        p.Character.HumanoidRootPart.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                        p.Character.HumanoidRootPart.Transparency = 0.8
                        p.Character.HumanoidRootPart.CanCollide = false
                    else
                        -- เพื่อนขนาดปกติ
                        p.Character.HumanoidRootPart.Size = Vector3.new(2, 2, 1)
                        p.Character.HumanoidRootPart.Transparency = 1
                    end
                end
            end
        end
    end
end)

RefreshPlayers()
Rayfield:Notify({Title = "TeHub Premium", Content = "Aimbot ระบบ Smart Scan เริ่มทำงาน!", Duration = 3})
                                 
